const $=id=>document.getElementById(id);let cart=[];let password=localStorage.getItem('kaShopifyPassword')||'';
function headers(){return {'Content-Type':'application/json','X-App-Password':password}}
function msg(text,error=false){$('message').className=error?'message error':'message';$('message').textContent=text}
function parseContact(){const raw=$('rawContact').value.trim();const lines=raw.split(/\n+/).map(x=>x.trim()).filter(Boolean);const email=raw.match(/[\w.+-]+@[\w.-]+\.[A-Za-z]{2,}/)?.[0]||'';const phone=raw.match(/(?:\+49|0)[\d\s\/-]{7,}/)?.[0]?.trim()||'';const zipLine=lines.find(l=>/\b\d{5}\b/.test(l));const streetLine=lines.find(l=>/\d+[a-zA-Z]?\s*$/.test(l)&&l!==zipLine);const nameLine=lines.find(l=>l!==email&&l!==phone&&l!==zipLine&&l!==streetLine)||'';const names=nameLine.split(/\s+/);$('firstName').value=names.shift()||'';$('lastName').value=names.join(' ');$('email').value=email;$('phone').value=phone;if(streetLine)$('address1').value=streetLine;if(zipLine){const m=zipLine.match(/(\d{5})\s+(.+)/);if(m){$('zip').value=m[1];$('city').value=m[2]}}}
async function api(url,options={}){const r=await fetch(url,{...options,headers:{...headers(),...(options.headers||{})}});const d=await r.json();if(!r.ok)throw new Error(d.error||'Unbekannter Fehler');return d}
async function health(){try{const d=await api('/api/health');$('health').textContent=`Verbunden mit ${d.shop.name}`;return true}catch(e){$('health').textContent=e.message;return false}}
async function search(){const q=$('productSearch').value.trim();$('results').innerHTML='<p class="muted">Suche…</p>';try{const d=await api('/api/products?q='+encodeURIComponent(q));$('results').innerHTML=d.products.length?'':'<p class="muted">Keine Produkte gefunden.</p>';d.products.forEach(p=>{const el=document.createElement('div');el.className='result';el.innerHTML=`<div><strong>${p.title}</strong><br><small>${p.variantTitle==='Default Title'?'':p.variantTitle+' · '}${p.sku?'SKU '+p.sku+' · ':''}${Number(p.price).toFixed(2)} € · Bestand ${p.inventoryQuantity??'?'}</small></div><button>Hinzufügen</button>`;el.querySelector('button').onclick=()=>{const found=cart.find(x=>x.variantId===p.id);if(found)found.quantity++;else cart.push({variantId:p.id,title:p.title,variantTitle:p.variantTitle,quantity:1,price:Number(p.price),originalPrice:Number(p.price)});renderCart()};$('results').appendChild(el)})}catch(e){$('results').innerHTML=`<p class="message error">${e.message}</p>`}}
function renderCart(){if(!cart.length){$('cart').innerHTML='<p class="muted">Noch kein Produkt ausgewählt.</p>';return}$('cart').innerHTML='';cart.forEach((x,i)=>{const el=document.createElement('div');el.className='cartrow';el.innerHTML=`<div><strong>${x.title}</strong><br><small>${x.variantTitle==='Default Title'?'':x.variantTitle}</small></div><div class="cartcontrols"><label>Menge <input class="qty" type="number" min="1" value="${x.quantity}"></label><label>Preis € <input class="price" type="number" min="0" step="0.01" value="${x.price.toFixed(2)}"></label><button class="secondary">Entfernen</button></div>`;el.querySelector('.qty').onchange=e=>x.quantity=Math.max(1,Number(e.target.value));el.querySelector('.price').onchange=e=>x.price=Math.max(0,Number(e.target.value));el.querySelector('button').onclick=()=>{cart.splice(i,1);renderCart()};$('cart').appendChild(el)})}
function customer(){const selected=$('countryCode').value;const countryCode=(selected==='other'?$('customCountryCode').value:selected).trim().toUpperCase()||'DE';return{firstName:$('firstName').value.trim(),lastName:$('lastName').value.trim(),company:$('company').value.trim(),email:$('email').value.trim(),phone:$('phone').value.trim(),address1:$('address1').value.trim(),address2:$('address2').value.trim(),zip:$('zip').value.trim(),city:$('city').value.trim(),countryCode}}
async function create(mode){msg('Bestellung wird angelegt…');try{const body={customer:customer(),items:cart,shipping:{title:$('shippingTitle').value.trim(),price:Number($('shippingPrice').value)},note:$('note').value.trim(),mode};const d=await api('/api/orders',{method:'POST',body:JSON.stringify(body)});$('message').className='message';$('message').innerHTML=`${d.type==='order'?'Bestellung':'Bestellentwurf'} ${d.name} wurde angelegt. <a href="${d.adminUrl}" target="_blank">In Shopify öffnen</a>${d.invoiceUrl?` · <a href="${d.invoiceUrl}" target="_blank">Zahlungslink</a>`:''}`;}catch(e){msg(e.message,true)}}
$('parseBtn').onclick=parseContact;$('searchBtn').onclick=search;$('productSearch').onkeydown=e=>{if(e.key==='Enter')search()};$('draftBtn').onclick=()=>create('draft');$('paidBtn').onclick=()=>create('paid');$('settingsBtn').onclick=()=>{$('password').value=password;$('settings').showModal()};$('savePassword').onclick=async e=>{e.preventDefault();password=$('password').value;localStorage.setItem('kaShopifyPassword',password);if(await health())setTimeout(()=>$('settings').close(),500)};$('shippingPreset').onchange=e=>{if(e.target.value==='custom')return;const [price,title]=e.target.value.split('|');$('shippingPrice').value=price;$('shippingTitle').value=title};if(!password)setTimeout(()=>$('settings').showModal(),200);

$('countryCode').onchange=e=>{$('customCountryCode').hidden=e.target.value!=='other';if(e.target.value!=='other')$('customCountryCode').value=''};
